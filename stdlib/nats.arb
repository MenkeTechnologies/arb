# nats — subject traffic dashboard from a live nats subscription
#   nats sub ">" | arb -p nats
bars .subjects
source .subjects { in; match /Received on/; extract /"([^"]+)"/; tally }
gauge .messages -max 1000
source .messages { in; match /Received on/; count }
tail .payloads
source .payloads { in; reject /Received on/; nonempty }

test "subject tally" {
  given "[#1] Received on \"orders.new\"" "payload one" "[#2] Received on \"orders.new\"" "payload two" "[#3] Received on \"users.signup\""
  run { in; match /Received on/; extract /"([^"]+)"/; tally }
  want "orders.new\t2" "users.signup\t1"
}
test "message count" {
  given "[#1] Received on \"orders.new\"" "payload one" "[#2] Received on \"users.signup\"" "payload two"
  run { in; match /Received on/; count }
  want "2"
}

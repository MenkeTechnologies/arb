# mtr — per-hop latency and packet-loss dashboard from an mtr report
#   mtr -r target | arb -p mtr
spark .latency
source .latency { in; reject /Loss%/; field 6; numeric }
gauge .maxloss -max 100
source .maxloss { in; reject /Loss%/; field 3; cut % 1; max }
tail .hops
source .hops { in; reject /Loss%/; field 2 }

test "latency numeric" {
  given "HOST Loss% Snt Last Avg Best Wrst StDev" "1.|-- gw 0.0% 10 1.2 1.3 1.0 2.0 0.3" "2.|-- isp 10.0% 10 5.2 5.5 5.0 8.0 0.9"
  run { in; reject /Loss%/; field 6; numeric }
  want "1.3" "5.5"
}
test "max loss" {
  given "HOST Loss% Snt Last Avg Best Wrst StDev" "1.|-- gw 0.0% 10 1.2 1.3 1.0 2.0 0.3" "2.|-- isp 10.0% 10 5.2 5.5 5.0 8.0 0.9"
  run { in; reject /Loss%/; field 3; cut % 1; max }
  want "10"
}

# newrelic — APM entity health dashboard from newrelic CLI JSON output
#   newrelic apm application list | arb -p newrelic
bars .severity
source .severity { in.json; field alertSeverity; tally }
gauge .reporting -max 200
source .reporting { in.json; field reporting; contains true; count }
tail .apps
source .apps { in.json; field name }

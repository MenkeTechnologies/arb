# puppet — severity/change dashboard from a puppet agent run
#   puppet agent -t | arb -p puppet
bars .levels
source .levels { in; nonempty; field 1; tally }
gauge .errors -max 50
source .errors { in; match /^Error:/; count }
tail .changes
source .changes { in; match /Notice:/; contains Stage }

test "message levels" {
    given "Notice: applying configuration" "Error: failed to apply catalog" "Notice: finished run"
    run { in; nonempty; field 1; tally }
    want "Notice:\t2" "Error:\t1"
}
test "error count" {
    given "Error: could not retrieve catalog" "Notice: applied" "Error: failed to apply"
    run { in; match /^Error:/; count }
    want "2"
}

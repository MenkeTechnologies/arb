# aws — CloudTrail event names, error counts, and request latency
#   aws cloudtrail lookup-events --output json | jq -c '.Events[]' | arb -p aws
bars .events
source .events { in.json; field eventName; tally }
gauge .errors -max 500
source .errors { in.json; match /errorCode/; count }
tail .slow
source .slow { in.json; field requestParameters; match /Duration/ }

test "events tally by event name" { given "{\"eventName\":\"RunInstances\"}" "{\"eventName\":\"StopInstances\"}" "{\"eventName\":\"RunInstances\"}"; run { in.json; field eventName; tally }; want "RunInstances\t2" "StopInstances\t1" }
test "errors counts events with an errorCode" { given "{\"eventName\":\"A\",\"errorCode\":\"AccessDenied\"}" "{\"eventName\":\"B\"}" "{\"eventName\":\"C\",\"errorCode\":\"Throttled\"}"; run { in.json; match /errorCode/; count }; want "2" }

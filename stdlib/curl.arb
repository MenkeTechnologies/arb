# curl — HTTP status distribution, avg transfer time, live request log
#   curl -sw 'code=%{http_code} time=%{time_total} size=%{size_download}\n' -o /dev/null $URLS | arb -p curl
bars .codes
source .codes { in.logfmt; field code; tally }
gauge .avgtime -max 5
source .avgtime { in.logfmt; field time; avg }
gauge .maxsize -max 1000000
source .maxsize { in.logfmt; field size; max }
tail .log
source .log { in }

test "status code tally" {
  given "code=200 time=0.5 size=100" "code=200 time=1.5 size=200" "code=404 time=0.3 size=50"
  run { in.logfmt; field code; tally }
  want "200\t2" "404\t1"
}
test "avg transfer time" {
  given "code=200 time=0.5 size=100" "code=200 time=1.5 size=200"
  run { in.logfmt; field time; avg }
  want "1"
}
test "max download size" {
  given "code=200 time=0.5 size=100" "code=200 time=1.5 size=200"
  run { in.logfmt; field size; max }
  want "200"
}

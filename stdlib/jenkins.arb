# jenkins — CI job status dashboard from Jenkins REST API job JSON
#   curl -s .../api/json?tree=jobs[name,color] | jq -c '.jobs[]' | arb -p jenkins
bars .status
source .status { in.json; field color; tally }
gauge .jobs -max 500
source .jobs { in.json; field name; count }
tail .names
source .names { in.json; field name }

test "color tally" { given "{\"name\":\"build-app\",\"color\":\"blue\"}" "{\"name\":\"deploy\",\"color\":\"red\"}" "{\"name\":\"test\",\"color\":\"blue\"}"; run { in.json; field color; tally }; want "blue\t2" "red\t1" }
test "job count" { given "{\"name\":\"build-app\",\"color\":\"blue\"}" "{\"name\":\"deploy\",\"color\":\"red\"}" "{\"name\":\"test\",\"color\":\"blue\"}"; run { in.json; field name; count }; want "3" }

# pulsar — live event dashboard from JSON messages consumed off a Pulsar topic
#   pulsar-client consume -n 0 -s sub my-topic | arb -p pulsar
bars .status
source .status { in.json; field status; tally }
spark .latency
source .latency { in.json; field latency; numeric }
gauge .errors -max 100
source .errors { in.json; field level; match /ERROR/; count }
tail .events
source .events { in.json; field event }

test "status mix" {
    given "{\"status\":\"ok\",\"event\":\"a\"}" "{\"status\":\"fail\",\"event\":\"b\"}" "{\"status\":\"ok\",\"event\":\"c\"}"
    run { in.json; field status; tally }
    want "ok\t2" "fail\t1"
}
test "error count" {
    given "{\"level\":\"ERROR\"}" "{\"level\":\"INFO\"}" "{\"level\":\"ERROR\"}"
    run { in.json; field level; match /ERROR/; count }
    want "2"
}

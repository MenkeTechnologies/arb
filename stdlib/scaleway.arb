# scaleway — instance server state dashboard from scw list output
#   scw instance server list | arb -p scaleway
bars .state
source .state { in; reject /^ID/; field 4; tally }
gauge .servers -max 100
source .servers { in; reject /^ID/; count }
tail .names
source .names { in; reject /^ID/; field 2 }

test "server state tally skips header" {
  given "ID NAME TYPE STATE ZONE" "abc foo DEV1-S running fr-par-1" "def bar DEV1-S running fr-par-1" "ghi baz DEV1-S stopped fr-par-1"
  run { in; reject /^ID/; field 4; tally }
  want "running\t2" "stopped\t1"
}

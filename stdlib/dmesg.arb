# dmesg — kernel ring buffer: subsystem activity, error count, live log
#   dmesg | arb -p dmesg
bars .subsys
source .subsys { in; field 2; tally }
gauge .errors -max 50
source .errors { in; match /error|fail|warn/; count }
text .total
source .total { in; count }
tail .log
source .log { in }

test "error count" {
  given "[1.2] usb new device" "[2.3] EXT4-fs error bad block" "[3.4] task hung failure detected"
  run { in; match /error|fail|warn/; count }
  want "2"
}
test "total messages" {
  given "[1.2] usb new device" "[2.3] EXT4-fs mounted" "[3.4] eth0 link up"
  run { in; count }
  want "3"
}

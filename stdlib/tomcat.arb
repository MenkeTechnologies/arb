# tomcat — HTTP status/request dashboard from Tomcat access logs
#   tail -f logs/localhost_access_log.txt | arb -p tomcat
bars .status
source .status { in; field 9; tally }
gauge .hits -max 1000
source .hits { in; nonempty; count }
tail .errors
source .errors { in; match /" (4|5)[0-9][0-9] / }

test "status tally" {
  given "127.0.0.1 - - [10/Oct/2000:13:55:36 -0700] \"GET /foo HTTP/1.1\" 200 2326" "127.0.0.1 - - [10/Oct/2000:13:55:37 -0700] \"GET /bar HTTP/1.1\" 200 512" "127.0.0.1 - - [10/Oct/2000:13:55:38 -0700] \"GET /baz HTTP/1.1\" 404 71"
  run { in; field 9; tally }
  want "200\t2" "404\t1"
}
test "error lines" {
  given "127.0.0.1 - - [10/Oct/2000:13:55:36 -0700] \"GET /foo HTTP/1.1\" 200 2326" "127.0.0.1 - - [10/Oct/2000:13:55:38 -0700] \"GET /baz HTTP/1.1\" 404 71"
  run { in; match /" (4|5)[0-9][0-9] / }
  want "127.0.0.1 - - [10/Oct/2000:13:55:38 -0700] \"GET /baz HTTP/1.1\" 404 71"
}

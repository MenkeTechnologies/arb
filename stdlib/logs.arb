# stdlib preset: logs — level breakdown + live tail for a JSON log stream.
#   kubectl logs -f deploy/api | arb -p logs
bars .levels
tail .log
source .levels { in.json; field level; tally }
source .log    { in }

test "level tally" {
  given "{\"level\":\"info\",\"msg\":\"a\"}" "{\"level\":\"error\",\"msg\":\"b\"}" "{\"level\":\"info\",\"msg\":\"c\"}"
  run { in.json; field level; tally }
  want "info\t2" "error\t1"
}

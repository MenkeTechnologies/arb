# grafana — server log dashboard from Grafana JSON structured logs
#   grafana server | arb -p grafana
bars .levels
source .levels { in.json; field level; tally }
gauge .errors -max 100
source .errors { in.json; field level; match /error/; count }
tail .messages
source .messages { in.json; field msg }

test "level tally" { given "{\"level\":\"info\",\"msg\":\"a\"}" "{\"level\":\"error\",\"msg\":\"b\"}" "{\"level\":\"info\",\"msg\":\"c\"}"; run { in.json; field level; tally }; want "info\t2" "error\t1" }
test "error count" { given "{\"level\":\"info\"}" "{\"level\":\"error\"}" "{\"level\":\"error\"}"; run { in.json; field level; match /error/; count }; want "2" }

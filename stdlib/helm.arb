# helm — release status dashboard from helm list JSON
#   helm list -A -o json | arb -p helm
bars .status
source .status { in.json; field status; tally }
gauge .releases -max 100
source .releases { in.json; field name; count }
tail .names
source .names { in.json; field name }

test "status tally" { given "{\"name\":\"r1\",\"status\":\"deployed\"}" "{\"name\":\"r2\",\"status\":\"failed\"}" "{\"name\":\"r3\",\"status\":\"deployed\"}"; run { in.json; field status; tally }; want "deployed\t2" "failed\t1" }

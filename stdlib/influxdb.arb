# influxdb — Flux query dashboard from influx annotated-CSV output
#   influx query --raw 'from(bucket:"x")|>range(start:-1h)' | arb -p influxdb
bars .measurements
source .measurements { in.csv; field _measurement; nonempty; tally }
bars .fields
source .fields { in.csv; field _field; nonempty; tally }
gauge .rows -max 1000
source .rows { in.csv; field _value; numeric; count }
tail .values
source .values { in.csv; field _value; nonempty }

test "measurement tally" { given ",result,table,_time,_value,_field,_measurement" ",_result,0,2020-01-01,10,temp,cpu" ",_result,0,2020-01-01,20,temp,cpu" ",_result,1,2020-01-01,5,load,mem"; run { in.csv; field _measurement; nonempty; tally }; want "cpu\t2" "mem\t1" }
test "row count" { given ",result,table,_time,_value,_field,_measurement" ",_result,0,2020-01-01,10,temp,cpu" ",_result,0,2020-01-01,20,temp,cpu"; run { in.csv; field _value; numeric; count }; want "2" }

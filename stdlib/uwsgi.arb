# uwsgi — worker status and request dashboard from JSON stats output
#   uwsgi --connect-and-read /tmp/stats.sock | arb -p uwsgi
bars .status
source .status { in.json; field status; tally }
gauge .requests -max 100000
source .requests { in.json; field requests; sum }
tail .rt
source .rt { in.json; field avg_rt }

test "requests sum" {
  given "{\"status\":\"idle\",\"requests\":100}" "{\"status\":\"busy\",\"requests\":50}"
  run { in.json; field requests; sum }
  want "150"
}
test "worker status tally" {
  given "{\"status\":\"idle\",\"requests\":100}" "{\"status\":\"idle\",\"requests\":10}" "{\"status\":\"busy\",\"requests\":50}"
  run { in.json; field status; tally }
  want "idle\t2" "busy\t1"
}
